-- // Cosmetic grid
-- ============================================================
RefreshCosmeticGrid = function()
    -- Clear old cosmetic spin connections
    for k,c in pairs(spinConns) do
        if k:sub(1,2)~="w_" then
            if type(c)=="userdata" and c.Connected then c:Disconnect() end
            spinConns[k]=nil
        end
    end
    for _, cd in pairs(cCells) do if cd and cd.frame then cd.frame:Destroy() end end
    cCells={}

    local items={}
    local ft=CFilter.Text:lower()
    if selCosType=="skin" then
        if not selWeapon then CGridScroll.CanvasSize=UDim2.new(0,0,0,0); return end
        items=WeaponSkins[selWeapon] or {}
    elseif selCosType=="wrap" then items=allWraps
    elseif selCosType=="charm" then items=allCharms end

    CGridLayout.CellSize=UDim2.fromOffset(CELL_W,CELL_H)

    local idx=0
    for _, itemName in ipairs(items) do
        if ft=="" or itemName:lower():find(ft,1,true) then
            idx+=1
            local isSel=(selCosmetic==itemName)
            local outer,inner,preview,nameLbl,btn=MakeCard(CGridFrame,idx,isSel)
            nameLbl.Text=itemName

            local thisItem=itemName
            local thisType=selCosType

            if thisType=="skin" then
                local imgLabel=Instance.new("ImageLabel")
                imgLabel.Size=UDim2.new(1,0,1,0); imgLabel.BackgroundTransparency=1
                imgLabel.ScaleType=Enum.ScaleType.Fit; imgLabel.Image=""; imgLabel.ZIndex=9; imgLabel.Parent=preview

                local ck="skin|"..thisItem
                if imageCache[ck] and imageCache[ck]~="" then imgLabel.Image=imageCache[ck]
                else task.defer(function()
                    local id=GetSkinImage(thisItem)
                    if id~="" and imgLabel.Parent then imgLabel.Image=id end
                end) end

                local spinKey="s_"..thisItem
                btn.MouseEnter:Connect(function()
                    if selCosmetic~=thisItem then Tween(inner,{BackgroundColor3=C.ItemSel},0.08) end
                    Tween(preview,{Size=UDim2.new(1,-1,0,PREVIEW_H+3),Position=UDim2.fromOffset(0,0)},0.1)
                    if not spinConns[spinKey] then spinConns[spinKey]=StartSpin2D(imgLabel) end
                end)
                btn.MouseLeave:Connect(function()
                    if selCosmetic~=thisItem then Tween(inner,{BackgroundColor3=C.Main},0.08) end
                    Tween(preview,{Size=UDim2.new(1,-4,0,PREVIEW_H),Position=UDim2.fromOffset(2,2)},0.1)
                    if spinConns[spinKey] then spinConns[spinKey]:Disconnect(); spinConns[spinKey]=nil; imgLabel.Rotation=0 end
                end)
                btn.MouseButton1Click:Connect(function()
                    if selCosmetic and cCells[selCosmetic] then
                        local p=cCells[selCosmetic]
                        Tween(p.inner,{BackgroundColor3=C.Main},0.1)
                        if p.name then Tween(p.name,{TextColor3=C.SubFont},0.1) end
                    end
                    selCosmetic=thisItem
                    Tween(inner,{BackgroundColor3=C.ItemSel},0.1)
                    Tween(nameLbl,{TextColor3=C.Font},0.1)
                    if selWeapon then
                        if SkinChanger:ApplySkinModel(selWeapon,thisItem) then
                            saveSkinsFile(); ApplyLive(selWeapon)
                            task.defer(function()
                                local id=GetSkinImage(thisItem)
                                if id=="" then id=GetWeaponImage(selWeapon) end
                                if wCells[selWeapon] and id~="" then wCells[selWeapon].img.Image=id end
                            end)
                        end
                    end
                end)
                cCells[thisItem]={frame=outer,inner=inner,name=nameLbl}

            else
                -- 3D viewport: charm/wrap with up/down spin on hover
                task.defer(function()
                    if not preview.Parent then return end
                    if thisType=="wrap" then MakeWrapViewport(preview,thisItem)
                    elseif thisType=="charm" then MakeCharmViewport(preview,thisItem) end
                end)

                btn.MouseEnter:Connect(function()
                    if selCosmetic~=thisItem then Tween(inner,{BackgroundColor3=C.ItemSel},0.08) end
                    Tween(preview,{Size=UDim2.new(1,-1,0,PREVIEW_H+3),Position=UDim2.fromOffset(0,0)},0.1)
                end)
                btn.MouseLeave:Connect(function()
                    if selCosmetic~=thisItem then Tween(inner,{BackgroundColor3=C.Main},0.08) end
                    Tween(preview,{Size=UDim2.new(1,-4,0,PREVIEW_H),Position=UDim2.fromOffset(2,2)},0.1)
                end)
                btn.MouseButton1Click:Connect(function()
                    if selCosmetic and cCells[selCosmetic] then
                        local p=cCells[selCosmetic]
                        Tween(p.inner,{BackgroundColor3=C.Main},0.1)
                        if p.name then Tween(p.name,{TextColor3=C.SubFont},0.1) end
                    end
                    selCosmetic=thisItem
                    Tween(inner,{BackgroundColor3=C.ItemSel},0.1)
                    Tween(nameLbl,{TextColor3=C.Font},0.1)
                    if selWeapon then
                        if thisType=="wrap" then
                            local d=SkinChanger:CloneCosmetic(thisItem,"Wrap",{inverted=invertedEnabled})
                            if d then
                                SkinChanger.equipped[selWeapon]=SkinChanger.equipped[selWeapon] or {}
                                SkinChanger.equipped[selWeapon].Wrap=d
                                SkinChanger.equipped[selWeapon].Name=selWeapon
                                saveSkinsFile(); ApplyLive(selWeapon)
                            end
                        elseif thisType=="charm" then
                            local d=SkinChanger:CloneCosmetic(thisItem,"Charm",{})
                            if d then
                                SkinChanger.equipped[selWeapon]=SkinChanger.equipped[selWeapon] or {}
                                SkinChanger.equipped[selWeapon].Charm=d
                                SkinChanger.equipped[selWeapon].Name=selWeapon
                                saveSkinsFile(); ApplyLive(selWeapon)
                            end
                        end
                    end
                end)
                cCells[thisItem]={frame=outer,inner=inner,name=nameLbl}
            end
        end
    end

    task.defer(function()
        local h=CGridLayout.AbsoluteContentSize.Y+8
        CGridScroll.CanvasSize=UDim2.new(0,0,0,h)
        CGridFrame.Size=UDim2.new(1,0,0,h)
    end)
end

