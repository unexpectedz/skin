local _tintActive=false
local _tintOrigColors={}
local _tintLastVm=nil
local function StartTintLoop()
    if _tintActive then return end
    _tintActive=true
    task.spawn(function()
        local fc
        for _=1,30 do fc=GetFC(); if fc then break end; task.wait(0.5) end
        if not fc then _tintActive=false; return end
        local t=0
        while _tintActive do
            t=t+0.016
            local lf=fc.LocalFighter
            local item=lf and lf.EquippedItem
            local vm=item and item.ViewModel
            if vm~=_tintLastVm then
                for part,color in pairs(_tintOrigColors) do pcall(function() part.Color=color end) end
                _tintOrigColors={}
                if vm and vm.ItemModel then
                    for _,p in ipairs(vm.ItemModel:GetDescendants()) do
                        if p:IsA("BasePart") then _tintOrigColors[p]=p.Color end
                    end
                end
                _tintLastVm=vm
            end
            if vm and vm.ItemModel then
                local color
                local mode=GunCustomConfig.tintMode
                if mode=="rainbow" then
                    color=Color3.fromHSV((t*GunCustomConfig.tintSpeed)%1,0.8,1)
                elseif mode=="multiply" then
                    color=Color3.fromHSV((t*GunCustomConfig.tintSpeed*0.5)%1,0.5,1)
                else
                    color=GunCustomConfig.tintColor
                end
                pcall(function()
                    for _,p in ipairs(vm.ItemModel:GetDescendants()) do
                        if p:IsA("BasePart") then
                            if mode=="multiply" then
                                local orig=_tintOrigColors[p]
                                if orig then p.Color=Color3.new(orig.R*color.R,orig.G*color.G,orig.B*color.B) end
                            else
                                p.Color=color
                            end
                        end
                    end
                end)
            end
            task.wait(0.05)
        end
        for part,color in pairs(_tintOrigColors) do pcall(function() part.Color=color end) end
        _tintOrigColors={}; _tintLastVm=nil
    end)
end
