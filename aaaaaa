local function MakeSection(parent, yOff, title)
    local outer = Instance.new("Frame")
    outer.BackgroundColor3 = C.BG
    outer.BorderColor3 = C.Outline
    outer.BorderMode = Enum.BorderMode.Inset
    outer.Size = UDim2.new(1,-8, 0, 100)
    outer.Position = UDim2.fromOffset(4, yOff)
    outer.ZIndex = 4
    outer.Parent = parent

    local inner = Instance.new("Frame")
    inner.BackgroundColor3 = C.BG
    inner.BorderColor3 = C.Black
    inner.Size = UDim2.new(1,-2,1,-2); inner.Position = UDim2.new(0,1,0,1)
    inner.ZIndex = 4; inner.Parent = outer

    local hlBar = Instance.new("Frame")
    hlBar.BackgroundColor3 = C.Accent; hlBar.BorderSizePixel = 0
    hlBar.Size = UDim2.new(1,0,0,2); hlBar.ZIndex = 5; hlBar.Parent = inner

    LibLabel(inner, title,
        UDim2.new(1,0,0,18), UDim2.fromOffset(4,2),
        14, 5, Enum.TextXAlignment.Left)

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Position = UDim2.fromOffset(0, 20)
    container.Size = UDim2.new(1,0,1,-22)
    container.ZIndex = 5
    container.Parent = inner

    local function SetHeight(h)
        outer.Size = UDim2.new(1,-8,0,h)
    end

    return container, SetHeight, outer
end

-- Helper: toggle row with one or more inline color pickers on the right
-- colorDefs = array of {label, initColor, onChanged}
-- Returns the toggle frame. Row height = 18.
local function LibToggleWithColors(parent, labelText, initState, yOffset, containerWidth, onToggle, colorDefs)
    -- Checkbox
    local toggleOuter = Instance.new("Frame")
    toggleOuter.BackgroundColor3 = C.Black
    toggleOuter.BorderColor3 = C.Black
    toggleOuter.Size = UDim2.fromOffset(13, 13)
    toggleOuter.Position = UDim2.fromOffset(6, yOffset + 2)
    toggleOuter.ZIndex = 5
    toggleOuter.Parent = parent

    local toggleInner = Instance.new("Frame")
    toggleInner.BackgroundColor3 = initState and C.Accent or C.Main
    toggleInner.BorderColor3 = initState and C.AccentDk or C.Outline
    toggleInner.BorderMode = Enum.BorderMode.Inset
    toggleInner.Size = UDim2.new(1,0,1,0)
    toggleInner.ZIndex = 6
    toggleInner.Parent = toggleOuter

    -- Label right of checkbox
    local textLbl = LibLabel(toggleInner, labelText,
        UDim2.fromOffset(containerWidth - 26, 13),
        UDim2.fromOffset(16, 0),
        14, 6, Enum.TextXAlignment.Left)
    textLbl.TextColor3 = C.Font

    -- Click region (covers checkbox + label text)
    local toggleRegion = Instance.new("Frame")
    toggleRegion.BackgroundTransparency = 1
    toggleRegion.Size = UDim2.fromOffset(containerWidth - 6, 13)
    toggleRegion.ZIndex = 8
    toggleRegion.Parent = toggleOuter

    local state = initState
    local function refresh()
        toggleInner.BackgroundColor3 = state and C.Accent or C.Main
        toggleInner.BorderColor3 = state and C.AccentDk or C.Outline
    end
    toggleRegion.MouseEnter:Connect(function()
        if not state then toggleOuter.BorderColor3 = C.Accent end
    end)
    toggleRegion.MouseLeave:Connect(function()
        if not state then toggleOuter.BorderColor3 = C.Black end
    end)
    toggleRegion.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            state = not state
            toggleOuter.BorderColor3 = C.Black
            refresh()
            onToggle(state)
        end
    end)
    refresh()

    -- Inline color pickers stacked vertically from the right edge
    -- Each swatch is 28x14, placed right-aligned, with a small label above it
    -- We place them to the right of the label text in the same row area
    if colorDefs then
        local swatchX = containerWidth - 6  -- right edge of container
        for i = #colorDefs, 1, -1 do
            local cd = colorDefs[i]
            swatchX = swatchX - 32  -- 28px swatch + 4px gap

            -- The actual swatch (LibColorPicker needs parent+yOffset, returns displayFrame)
            -- We'll manually create a mini swatch since LibColorPicker positions by yOffset
            local function GetDarker(c)
                local h,s,v = Color3.toHSV(c)
                return Color3.fromHSV(h,s,v/1.5)
            end

            local swatchFrame = Instance.new("Frame")
            swatchFrame.BackgroundColor3 = cd.initColor
            swatchFrame.BorderColor3 = GetDarker(cd.initColor)
            swatchFrame.BorderMode = Enum.BorderMode.Inset
            swatchFrame.Size = UDim2.fromOffset(28, 14)
            swatchFrame.Position = UDim2.fromOffset(swatchX, yOffset + 1)
            swatchFrame.ZIndex = 6
            swatchFrame.Parent = parent

            -- Full picker popup (reuse LibColorPicker logic inline)
            local curColor = cd.initColor
            local pickerOuter = Instance.new("Frame")
            pickerOuter.Name = "Color"
            pickerOuter.BackgroundColor3 = Color3.new(1,1,1)
            pickerOuter.BorderColor3 = Color3.new(0,0,0)
            pickerOuter.Size = UDim2.fromOffset(230, 253)
            pickerOuter.Visible = false
            pickerOuter.ZIndex = 15
            pickerOuter.Parent = ScreenGui

            local function RecalcPickerPos()
                pickerOuter.Position = UDim2.fromOffset(swatchFrame.AbsolutePosition.X, swatchFrame.AbsolutePosition.Y + 18)
            end
            RecalcPickerPos()
            swatchFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(RecalcPickerPos)

            local pickerInner = Instance.new("Frame")
            pickerInner.BackgroundColor3 = C.BG; pickerInner.BorderColor3 = C.Outline
            pickerInner.BorderMode = Enum.BorderMode.Inset; pickerInner.Size = UDim2.new(1,0,1,0)
            pickerInner.ZIndex = 16; pickerInner.Parent = pickerOuter

            local phlBar = Instance.new("Frame")
            phlBar.BackgroundColor3 = C.Accent; phlBar.BorderSizePixel = 0
            phlBar.Size = UDim2.new(1,0,0,2); phlBar.ZIndex = 17; phlBar.Parent = pickerInner

            local titleLbl2 = Instance.new("TextLabel")
            titleLbl2.BackgroundTransparency = 1; titleLbl2.Font = FONT
            titleLbl2.TextColor3 = C.Font; titleLbl2.TextSize = 14; titleLbl2.TextStrokeTransparency = 0
            titleLbl2.Position = UDim2.fromOffset(5,5); titleLbl2.Size = UDim2.new(1,0,0,14)
            titleLbl2.Text = cd.label; titleLbl2.TextXAlignment = Enum.TextXAlignment.Left
