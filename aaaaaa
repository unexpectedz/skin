SkinChanger.InitializeModules = function(self)
    pcall(function()
        local controllers = LocalPlayer.PlayerScripts:WaitForChild("Controllers",10)
        local modules     = ReplicatedStorage:WaitForChild("Modules",10)
        if modules then
            self.EnumLibrary     = require(modules:WaitForChild("EnumLibrary",10))
            self.CosmeticLibrary = require(modules:WaitForChild("CosmeticLibrary",10))
            self.ItemLibrary     = require(modules:WaitForChild("ItemLibrary",10))
            self.RepClass        = require(modules:WaitForChild("ReplicatedClass",10))
        end
        if controllers then
            self.DataController = require(controllers:WaitForChild("PlayerDataController",10))
        end
        if self.EnumLibrary and self.EnumLibrary.WaitForEnumBuilder then
            self.EnumLibrary:WaitForEnumBuilder()
        end
        modulesLoaded = true
        if RefreshAllWeaponImages then RefreshAllWeaponImages() end
    end)
end

SkinChanger.CloneCosmetic = function(self, name, ctype, opts)
    local data = {}
    if self.CosmeticLibrary and self.CosmeticLibrary.Cosmetics and self.CosmeticLibrary.Cosmetics[name] then
        for k,v in pairs(self.CosmeticLibrary.Cosmetics[name]) do data[k]=v end
    end
    data.Name = name; data.Type = data.Type or ctype; data.Seed = data.Seed or math.random(1,999999)
    if self.EnumLibrary then
        local ok,enumId = pcall(self.EnumLibrary.ToEnum,self.EnumLibrary,name)
        if ok and enumId then data.Enum=enumId; data.ObjectID=data.ObjectID or enumId end
    end
    if opts and opts.inverted ~= nil then data.Inverted = opts.inverted end
    return data
end

SkinChanger.InitializeViewModelsPath = function(self)
    local ok,path = pcall(function() return LocalPlayer.PlayerScripts.Assets.ViewModels.Weapons end)
    if ok and path then self.viewModelsPath=path; return true end
    local s2,vm = pcall(function() return LocalPlayer.PlayerScripts.Assets.ViewModels end)
    if not(s2 and vm) then return false end
    local f=Instance.new("Folder"); f.Name="Weapons"; f.Parent=vm
    self.viewModelsPath=f; return true
end

SkinChanger.DiscoverAllSkinFolders = function(self)
    if not(self.viewModelsPath or self:InitializeViewModelsPath()) then return false end
    local root=self.viewModelsPath.Parent; local count=0
    local function search(folder,depth)
        if depth>6 then return end
        pcall(function()
            for _,child in ipairs(folder:GetChildren()) do
                if child:IsA("Folder") then
                    local hasModels=false
                    for _,item in ipairs(child:GetChildren()) do
                        if item:IsA("Model") then hasModels=true; break end
                    end
                    if hasModels then self.skinFolders[child.Name]=child; count+=1 end
                    task.wait(); search(child,depth+1)
                end
            end
        end)
    end
    search(root,0); return count>0
end

SkinChanger.BuildSkinDatabase = function(self)
    self.allSkins={}; local total=0
    for _,folder in pairs(self.skinFolders) do
        pcall(function()
            for _,model in ipairs(folder:GetChildren()) do
                if model:IsA("Model") and not self.allSkins[model.Name] then
                    self.allSkins[model.Name]={name=model.Name,model=model}; total+=1
                end
            end
        end)
    end
    return total
end

SkinChanger.FindSkinModel = function(self,skinName)
    if not skinName then return nil end
    if self.allSkins[skinName] then return self.allSkins[skinName].model end
    for _,folder in pairs(self.skinFolders) do
        local ok,model=pcall(function() return folder:IsA("Folder") and folder:FindFirstChild(skinName) or nil end)
        if ok and model then return model end
    end
    return nil
end

SkinChanger.GetOrCreateBackupFolder = function(self)
    if self.backupFolder and self.backupFolder.Parent then return self.backupFolder end
    if not(self.viewModelsPath or self:InitializeViewModelsPath()) then return nil end
    local ok,folder=pcall(function()
        local b=self.viewModelsPath:FindFirstChild("OriginalBackups")
        if not b then b=Instance.new("Folder"); b.Name="OriginalBackups"; b.Parent=self.viewModelsPath end
        return b
    end)
    if not ok then return nil end
    self.backupFolder=folder; return folder
end

SkinChanger.ApplySkinModel = function(self,weaponName,skinName)
    if not(self.viewModelsPath or self:InitializeViewModelsPath()) then return false end
    local weaponModel=self.viewModelsPath:FindFirstChild(weaponName)
    if not(weaponModel and weaponModel:IsA("Model")) then return false end
    local skinModel=self:FindSkinModel(skinName)
    if not skinModel then return false end
    local bf=self:GetOrCreateBackupFolder(); if not bf then return false end
    local bn=weaponName.."_Original"
    if not bf:FindFirstChild(bn) then
        local backup=weaponModel:Clone(); backup.Name=bn; backup.Parent=bf
    end
    weaponModel:Destroy()
    local nm=skinModel:Clone(); nm.Name=weaponName; nm.Parent=self.viewModelsPath
    local sd=self:CloneCosmetic(skinName,"Skin",{})
    if sd then
        self.equipped[weaponName]=self.equipped[weaponName] or {}
        self.equipped[weaponName].Skin=sd; self.equipped[weaponName].Name=weaponName
    end
    return true
end

SkinChanger.SetupHooks = function(self)
    if not(self.CosmeticLibrary and self.DataController) then return end
    self.CosmeticLibrary.OwnsCosmeticNormally    = function() return true end
    self.CosmeticLibrary.OwnsCosmeticUniversally = function() return true end
    self.CosmeticLibrary.OwnsCosmeticForWeapon   = function() return true end
    local oldOwns=self.CosmeticLibrary.OwnsCosmetic
    local _missingPfx=string.char(77,73,83,83,73,78,71,95)
    self.CosmeticLibrary.OwnsCosmetic=function(s,inv,name,weapon)
        if name:find(_missingPfx) then return oldOwns(s,inv,name,weapon) end
        return true
    end
    local oldGet=self.DataController.Get
    self.DataController.Get=function(s,key)
        local data=oldGet(s,key)
        if key=="Cosmetics" then
            local copy={}
            if data then for k,v in pairs(data) do copy[k]=v end end
            if self.CosmeticLibrary.Cosmetics then
                for name in pairs(self.CosmeticLibrary.Cosmetics) do
                    if not copy[name] then copy[name]=true end
                end
            end
            return copy
        end
        return data
    end
    local oldGetW=self.DataController.GetWeaponData
    self.DataController.GetWeaponData=function(s,wn)
        local data=oldGetW(s,wn); if not data then return nil end
        local merged=table.clone(data); merged.Name=wn
        if self.equipped[wn] then
            for ctype,cosData in pairs(self.equipped[wn]) do merged[ctype]=cosData end
        end
        return merged
    end
    pcall(function()
        local CI=require(LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem)
        local oldVM=CI._CreateViewModel
        CI._CreateViewModel=function(item,vm)
            local owner=item.ClientFighter and item.ClientFighter.Player
            local wname=item.Name
            if owner==LocalPlayer and self.equipped[wname] then
                self.constructingWeapon=wname
                local d=item:ToEnum("Data")
                if self.equipped[wname].Skin then
                    vm[d][item:ToEnum("Skin")]=self.equipped[wname].Skin
                    vm[d][item:ToEnum("Name")]=self.equipped[wname].Skin.Name
                end
                if self.equipped[wname].Wrap  then vm[d][item:ToEnum("Wrap")]=self.equipped[wname].Wrap   end
                if self.equipped[wname].Charm then vm[d][item:ToEnum("Charm")]=self.equipped[wname].Charm end
            end
            local r=oldVM(item,vm); self.constructingWeapon=nil; return r
        end
    end)
    pcall(function()
        local vmMod=LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem:FindFirstChild("ClientViewModel")
        if not vmMod then return end
        local CVM=require(vmMod); local oldNew=CVM.new
        CVM.new=function(repdata,clientItem)
            local owner=clientItem.ClientFighter and clientItem.ClientFighter.Player
            local wname=self.constructingWeapon or clientItem.Name
            if owner==LocalPlayer and self.equipped[wname] then
                local dk=self.RepClass:ToEnum("Data"); repdata[dk]=repdata[dk] or {}
                local cos=self.equipped[wname]
                if cos.Skin  then repdata[dk][self.RepClass:ToEnum("Skin")]=cos.Skin   end
                if cos.Wrap  then repdata[dk][self.RepClass:ToEnum("Wrap")]=cos.Wrap   end
                if cos.Charm then repdata[dk][self.RepClass:ToEnum("Charm")]=cos.Charm end
            end
            return oldNew(repdata,clientItem)
        end
    end)
    pcall(function()
        local oldImg=self.ItemLibrary.GetViewModelImageFromWeaponData
        self.ItemLibrary.GetViewModelImageFromWeaponData=function(s,wd,hi)
            if wd and wd.Skin and self.equipped[wd.Name] then
                local vm=s.ViewModels and s.ViewModels[wd.Skin.Name]
                if vm then return vm[hi and "ImageHighResolution" or "Image"] or vm.Image end
            end
            return oldImg(s,wd,hi)
        end
    end)
end

-- // Improved ApplyLive — uses FighterController directly for instant wrap/charm refresh
local function GetLiveItemsFromFC()
    local items = {}
    pcall(function()
        local FC = require(LocalPlayer.PlayerScripts.Controllers.FighterController)
        -- Try LocalFighter first (fastest path)
        if FC.LocalFighter then
            for _, item in pairs(FC.LocalFighter.Items or {}) do
                if item and item.Name and item.ViewModel then
                    items[item.Name] = item
                end
            end
        end
        -- Also sweep GameComponentsController if needed
        if not next(items) then
            local ok, GCC = pcall(require, LocalPlayer.PlayerScripts.Controllers.GameComponentsController)
            if ok and GCC then
                for _, comp in pairs(GCC.Components or {}) do
                    if comp.LocalFighter then
                        for _, item in pairs(comp.LocalFighter.Items or {}) do
                            if item and item.Name and item.ViewModel then items[item.Name] = item end
                        end
                    end
                    if comp.Fighters then
                        for _, fighter in pairs(comp.Fighters) do
                            if fighter.Player == LocalPlayer then
                                for _, item in pairs(fighter.Items or {}) do
                                    if item and item.Name and item.ViewModel then items[item.Name] = item end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    return items
end

-- Force-reequip the item by switching away and back (swaps to first other slot then returns)
-- Only called for Skin changes since those need a full rebuild
local function ForceReequipItem(weaponName)
    pcall(function()
        local FC = require(LocalPlayer.PlayerScripts.Controllers.FighterController)
        local lf = FC.LocalFighter
        if not lf then return end

        local targetIdx, currentIdx
        for i, item in pairs(lf.Items) do
            if item.Name == weaponName and item.IsEquipped then
                currentIdx = i
            end
        end
        if not currentIdx then return end

        -- Find any other slot to switch to briefly
        for i, item in pairs(lf.Items) do
            if i ~= currentIdx and item.Info then
                targetIdx = i
                break
            end
        end

        if targetIdx then
            lf:EquipItem(targetIdx)
            task.wait(0.05)
            lf:EquipItem(currentIdx)
        end
    end)
end

local function ApplyLive(weaponName)
    if not modulesLoaded then return end
    local eq = SkinChanger.equipped[weaponName]
    if not eq then return end

    local liveItems = GetLiveItemsFromFC()
    local item = liveItems[weaponName]

    -- For Wrap and Charm: apply directly to ViewModel right now
    if item and item.ViewModel then
        local vm = item.ViewModel
        if eq.Wrap then
            pcall(function() vm:Set("Wrap", eq.Wrap) end)
            pcall(function() vm:_UpdateWrap() end)
            -- Some versions use _Setup or _BuildWrap instead
            pcall(function() vm:_BuildWrap() end)
        end
        if eq.Charm then
            pcall(function() vm:Set("Charm", eq.Charm) end)
            pcall(function()
                if vm.Charm then vm.Charm:Destroy() end
                vm.Charm = nil
                vm:_Setup()
            end)
            -- Alternative charm rebuild path
            pcall(function() vm:_BuildCharm() end)
        end
    end

    -- For Skin: needs full ViewModel rebuild — use ForceReequip trick
    if eq.Skin then
        pcall(function()
            if item and item.ViewModel then
                local wasEquipped = item.IsEquipped
                local serial = item._serial
                if serial then
                    item.ViewModel:Destroy()
                    item.ViewModel = item:_CreateViewModel(serial.ViewModel)
                    pcall(function() item.ViewModel:SetParent(workspace.ViewModels.FirstPerson) end)
                    if wasEquipped then item.ViewModel:Equip(true) end
                    return -- success, no need to force reequip
                end
            end
            -- Fallback: force slot swap to trigger natural ViewModel rebuild
            ForceReequipItem(weaponName)
        end)
    end
end

