        toggleInner.BackgroundColor3 = state and C.Accent or C.Main
        toggleInner.BorderColor3 = state and C.AccentDk or C.Outline
    end

    toggleRegion.MouseEnter:Connect(function()
        if not state then toggleOuter.BorderColor3 = C.Accent end
    end)
