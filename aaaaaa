local weaponOrder = {}
for wname in pairs(WeaponSkins) do table.insert(weaponOrder, wname) end
table.sort(weaponOrder)

local function BuildWeaponList(filter)
    -- Clear spins
    for k,c in pairs(spinConns) do
        if type(c)=="userdata" and c.Connected then c:Disconnect() end
    end
    spinConns = {}
    for _, cd in pairs(wCells) do if cd and cd.frame then cd.frame:Destroy() end end
    wCells = {}

    local idx = 0
    for _, wname in ipairs(weaponOrder) do
        if not filter or filter=="" or wname:lower():find(filter:lower(),1,true) then
            idx += 1
            local isSel = (selWeapon==wname)
            local outer, inner, preview, nameLbl, btn = MakeCard(WGridScroll, idx, isSel)
            nameLbl.Text = wname

            local img = Instance.new("ImageLabel")
            img.Size = UDim2.new(1,0,1,0); img.BackgroundTransparency = 1
            img.ScaleType = Enum.ScaleType.Fit; img.Image = ""; img.ZIndex = 9; img.Parent = preview

            local thisName = wname
            local cached = imageCache["W_"..thisName]
            if cached and cached~="" then img.Image=cached
            else task.defer(function()
                local id=GetWeaponImage(thisName)
                if id~="" and img.Parent then img.Image=id end
            end) end

            local spinKey = "w_"..thisName
            btn.MouseEnter:Connect(function()
                if selWeapon~=thisName then Tween(inner,{BackgroundColor3=C.ItemSel},0.08) end
                Tween(preview,{Size=UDim2.new(1,-1,0,PREVIEW_H+3),Position=UDim2.fromOffset(0,0)},0.1)
                if not spinConns[spinKey] then spinConns[spinKey]=StartSpin2D(img) end
            end)
            btn.MouseLeave:Connect(function()
                if selWeapon~=thisName then Tween(inner,{BackgroundColor3=C.Main},0.08) end
                Tween(preview,{Size=UDim2.new(1,-4,0,PREVIEW_H),Position=UDim2.fromOffset(2,2)},0.1)
                if spinConns[spinKey] then spinConns[spinKey]:Disconnect(); spinConns[spinKey]=nil; img.Rotation=0 end
            end)
            btn.MouseButton1Click:Connect(function()
                -- deselect previous
                if selWeapon and wCells[selWeapon] then
                    local p=wCells[selWeapon]
                    Tween(p.inner,{BackgroundColor3=C.Main},0.1)
                    Tween(p.name,{TextColor3=C.SubFont},0.1)
                end
                selWeapon=thisName; selCosmetic=nil
                Tween(inner,{BackgroundColor3=C.ItemSel},0.1)
                Tween(nameLbl,{TextColor3=C.Font},0.1)
                RefreshCosmeticGrid()
            end)
            btn.MouseButton2Click:Connect(function()
                if SkinChanger.equipped[thisName] then
                    SkinChanger.equipped[thisName].Skin=nil
                    saveSkinsFile()
                end
            end)
            wCells[wname]={frame=outer,inner=inner,img=img,name=nameLbl}
        end
    end
    task.defer(function()
        WGridScroll.CanvasSize=UDim2.new(0,0,0,WGridLayout.AbsoluteContentSize.Y+8)
    end)
end

