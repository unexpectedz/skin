-- Up/down spin for 2D images (rotate on X axis visually = top-bottom oscillation)
local function StartSpin2D(img)
    local t = 0
    local conn = RunService.RenderStepped:Connect(function(dt)
        t = t + dt * 2
        -- Up/down = oscillate on "vertical tilt" using rotation + ScaleType.Fit
        -- We simulate up/down by tilting: positive rotation = tip clockwise
        img.Rotation = math.sin(t) * 18
    end)
    return conn
end

local function MakeCard(parent, layoutOrder, isSelected)
    local outer = Instance.new("Frame")
    outer.BackgroundColor3 = C.Black; outer.BorderSizePixel = 0
    outer.ZIndex = 6; outer.LayoutOrder = layoutOrder; outer.Parent = parent

    local inner = Instance.new("Frame")
    inner.BackgroundColor3 = isSelected and C.ItemSel or C.Main
    inner.BorderColor3 = C.Border; inner.BorderMode = Enum.BorderMode.Inset
    inner.Size = UDim2.new(1,0,1,0); inner.ZIndex = 7; inner.Parent = outer
    MakeGradient(inner)

    -- preview area: large, no border color trickery
    local preview = Instance.new("Frame")
    preview.BackgroundColor3 = C.Background
    preview.BorderColor3 = C.Border; preview.BorderMode = Enum.BorderMode.Inset
    preview.Size = UDim2.new(1,-4, 0, PREVIEW_H)
    preview.Position = UDim2.fromOffset(2, 2)
    preview.ZIndex = 8; preview.Parent = inner

    local nameLbl = MakeLabel(inner, {
        Size = UDim2.new(1,-2, 0, 18),
        Position = UDim2.new(0,1, 1,-19),
        Text = "",
        TextColor3 = isSelected and C.Font or C.SubFont,
        TextSize = 8, TextWrapped = true,
        TextYAlignment = Enum.TextYAlignment.Center,
        ZIndex = 8,
    })

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.ZIndex = 10; btn.Parent = inner

    return outer, inner, preview, nameLbl, btn
end

