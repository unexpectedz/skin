        local targetIdx, currentIdx
        for i, item in pairs(lf.Items) do
            if item.Name == weaponName and item.IsEquipped then currentIdx = i end
        end
        if not currentIdx then return end
        for i, item in pairs(lf.Items) do
            if i ~= currentIdx and item.Info then targetIdx = i; break end
        end
        if targetIdx then lf:EquipItem(targetIdx); task.wait(0.05); lf:EquipItem(currentIdx) end
    end)
