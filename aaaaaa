-- ============================================================
local function MakeWrapViewport(parent, wrapName)
    local vf = Instance.new("ViewportFrame")
    vf.Size = UDim2.new(1,0,1,0)
    vf.BackgroundTransparency = 1
    vf.LightDirection = Vector3.new(-1,-1,-1)
    vf.LightColor = Color3.new(1,1,1)
    vf.Ambient = Color3.fromRGB(200,200,200)
    vf.ZIndex = parent.ZIndex + 1
    vf.Parent = parent

    local cam = Instance.new("Camera")
    cam.FieldOfView = 35
    vf.CurrentCamera = cam
    cam.Parent = vf

    task.spawn(function()
        pcall(function()
            local ps = LocalPlayer.PlayerScripts
            local CL = SkinChanger.CosmeticLibrary
            local cosData = CL and CL.Cosmetics and CL.Cosmetics[wrapName]
            if not cosData or not cosData.WrapGroups then return end
            local wrapModelTemplate = ps.Assets.Misc:FindFirstChild("Wrap")
            if not wrapModelTemplate then return end
            local wrapModel = wrapModelTemplate:Clone()
            wrapModel.Parent = vf
            local meshParts = {}
            for _, p in ipairs(wrapModel:GetChildren()) do
                if p:IsA("BasePart") then table.insert(meshParts, p) end
            end
            for i, wg in ipairs(cosData.WrapGroups) do
                local part = meshParts[i]
                if part then
                    if wg.Color then part.Color = wg.Color end
                    if wg.Material then pcall(function() part.Material = wg.Material end) end
                    if wg.Transparency then part.Transparency = wg.Transparency end
                    if wg.Reflectance then part.Reflectance = wg.Reflectance end
                    if wg.MaterialVariant and wg.MaterialVariant ~= "" then
                        pcall(function() part.MaterialVariant = wg.MaterialVariant end)
                    end
                end
            end
            local cf0, size0 = wrapModel:GetBoundingBox()
            local dist = 2.5
            cam.CFrame = CFrame.new(cf0.Position + Vector3.new(0, 0, dist), cf0.Position)

            -- up/down spin: rotate X axis
            local angle = 0
            local spinning = false
            local spinConn
            parent.MouseEnter:Connect(function()
                if spinning then return end
                spinning = true
                spinConn = RunService.RenderStepped:Connect(function(dt)
                    angle = angle + 60 * dt
                    local cf, _ = wrapModel:GetBoundingBox()
                    wrapModel:SetPrimaryPartCFrame(CFrame.new(cf.Position) * CFrame.Angles(math.rad(angle), 0, 0))
                    cam.CFrame = CFrame.new(cf.Position + Vector3.new(0, 0, dist), cf.Position)
                end)
            end)
            parent.MouseLeave:Connect(function()
                spinning = false
                if spinConn then spinConn:Disconnect(); spinConn = nil end
            end)
        end)
    end)
    return vf
end

