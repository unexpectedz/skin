local function PositionTypePopup()
    local ap = TypeDropOuter.AbsolutePosition
    local as = TypeDropOuter.AbsoluteSize
    local itemH = 20
    TypePopup.Size = UDim2.fromOffset(as.X+2, #typeOptions*itemH+2)
    TypePopup.Position = UDim2.fromOffset(ap.X-1, ap.Y+as.Y+1)
end

local function CloseTypePopup()
    typePopupOpen = false; TypePopup.Visible = false; TypeArrow.Rotation = 0
end

local function BuildTypePopup()
    for _, c in pairs(TypePopupInner:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    for i, opt in ipairs(typeOptions) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1,0,0,20); row.BackgroundColor3 = (opt==selCosType) and C.ItemSel or C.Main
        row.BorderSizePixel = 0; row.ZIndex = 102; row.LayoutOrder = i; row.Parent = TypePopupInner

        MakeLabel(row, {
            Position = UDim2.fromOffset(6,0), Size = UDim2.new(1,-6,1,0),
            Text = opt, TextXAlignment = Enum.TextXAlignment.Left,
            TextSize = 12, TextColor3 = (opt==selCosType) and C.Font or C.SubFont, ZIndex = 103,
        })

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
        btn.Text = ""; btn.ZIndex = 104; btn.Parent = row

        local thisOpt = opt
        btn.MouseEnter:Connect(function() if thisOpt~=selCosType then Tween(row,{BackgroundColor3=C.ItemSel},0.08) end end)
        btn.MouseLeave:Connect(function() if thisOpt~=selCosType then Tween(row,{BackgroundColor3=C.Main},0.08) end end)
        btn.MouseButton1Click:Connect(function()
            selCosType = thisOpt; TypeDropDisplay.Text = thisOpt
            CloseTypePopup(); BuildTypePopup()
            UpdateInvertedVisible(selCosType)
            RefreshCosmeticGrid()
        end)
    end
end

TypeDropBtn.MouseButton1Click:Connect(function()
    if typePopupOpen then CloseTypePopup()
    else PositionTypePopup(); TypePopup.Visible=true; typePopupOpen=true; TypeArrow.Rotation=180 end
