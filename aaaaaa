            Instance.new("UIGradient", rbInner2).Color = ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.new(1,1,1)),ColorSequenceKeypoint.new(1,Color3.fromRGB(212,212,212))})
            local rgbBox2 = Instance.new("TextBox")
            rgbBox2.BackgroundTransparency = 1; rgbBox2.Position = UDim2.fromOffset(5,0)
            rgbBox2.Size = UDim2.new(1,-5,1,0); rgbBox2.Font = FONT
