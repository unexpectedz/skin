        curColor = Color3.fromHSV(pH, pS, pV)
        svMap.BackgroundColor3 = Color3.fromHSV(pH,1,1)

        displayFrame.BackgroundColor3 = curColor
        displayFrame.BackgroundTransparency = transparency
        displayFrame.BorderColor3 = GetDarker(curColor)

        if transpInner then
            transpInner.BackgroundColor3 = curColor
            transpCursor.Position = UDim2.new(1-transparency,0,0,0)
        end

        cursorOuter.Position = UDim2.new(pS,0,1-pV,0)
        hueCursor.Position = UDim2.new(0,0,pH,0)

        hexBox.Text = "#"..curColor:ToHex()
        rgbBox.Text = math.floor(curColor.R*255)..", "..math.floor(curColor.G*255)..", "..math.floor(curColor.B*255)

        onChanged(curColor, transparency)
    end

    hexBox.FocusLost:Connect(function(enter)
        if enter then
            local ok, res = pcall(Color3.fromHex, hexBox.Text)
            if ok and typeof(res) == "Color3" then
                pH, pS, pV = Color3.toHSV(res)
            end
        end
        DisplayPicker()
    end)

    rgbBox.FocusLost:Connect(function(enter)
        if enter then
            local r,g,b = rgbBox.Text:match("(%d+),%s*(%d+),%s*(%d+)")
            if r and g and b then pH, pS, pV = Color3.toHSV(Color3.fromRGB(r,g,b)) end
