                    DisplayPicker()
                    RunService.RenderStepped:Wait()
                end
            end
        end)
    end

    local pickerOpen = false
    displayFrame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if pickerOpen then
                pickerOuter.Visible = false; pickerOpen = false
            else
