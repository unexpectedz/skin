            local rbOuter2 = Instance.new("Frame")
            rbOuter2.BorderColor3 = Color3.new(0,0,0)
            rbOuter2.Position = UDim2.new(0.5,2,0,228); rbOuter2.Size = UDim2.new(0.5,-6,0,20)
            rbOuter2.ZIndex = 18; rbOuter2.Parent = pickerInner
            local rbInner2 = Instance.new("Frame")
            rbInner2.BackgroundColor3 = C.Main; rbInner2.BorderColor3 = C.Outline
            rbInner2.BorderMode = Enum.BorderMode.Inset; rbInner2.Size = UDim2.new(1,0,1,0)
