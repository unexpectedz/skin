local function ApplyLive(weaponName)
    if not modulesLoaded then return end
    local eq = SkinChanger.equipped[weaponName]
    if not eq then return end
    local liveItems = GetLiveItemsFromFC()
    local item = liveItems[weaponName]
    if item and item.ViewModel then
        local vm = item.ViewModel
        if eq.Wrap then
            pcall(function() vm:Set("Wrap", eq.Wrap) end)
            pcall(function() vm:_UpdateWrap() end)
            pcall(function() vm:_BuildWrap() end)
        end
        if eq.Charm then
            pcall(function() vm:Set("Charm", eq.Charm) end)
            pcall(function()
                if vm.Charm then vm.Charm:Destroy() end
                vm.Charm = nil; vm:_Setup()
            end)
            pcall(function() vm:_BuildCharm() end)
        end
    end
    if eq.Skin then
        pcall(function()
            if item and item.ViewModel then
                local wasEquipped = item.IsEquipped
                local serial = item._serial
                if serial then
                    item.ViewModel:Destroy()
                    item.ViewModel = item:_CreateViewModel(serial.ViewModel)
                    pcall(function() item.ViewModel:SetParent(workspace.ViewModels.FirstPerson) end)
                    if wasEquipped then item.ViewModel:Equip(true) end
                    return
                end
            end
            ForceReequipItem(weaponName)
        end)
    end
end

