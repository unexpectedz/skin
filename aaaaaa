        saveSkinsFile()
    elseif selCosType=="charm" then
        for weapon in pairs(WeaponSkins) do
            local d=SkinChanger:CloneCosmetic(selCosmetic,"Charm",{})
            if d then
                SkinChanger.equipped[weapon]=SkinChanger.equipped[weapon] or {}
                SkinChanger.equipped[weapon].Charm=d; SkinChanger.equipped[weapon].Name=weapon
                ApplyLive(weapon)
