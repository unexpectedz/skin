    if not selCosmetic then return end
    if selCosType=="wrap" then
        for weapon in pairs(WeaponSkins) do
            local d=SkinChanger:CloneCosmetic(selCosmetic,"Wrap",{inverted=invertedEnabled})
            if d then
                SkinChanger.equipped[weapon]=SkinChanger.equipped[weapon] or {}
                SkinChanger.equipped[weapon].Wrap=d; SkinChanger.equipped[weapon].Name=weapon
                ApplyLive(weapon)
