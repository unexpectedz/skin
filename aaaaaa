    listInner.BorderColor3 = C.Outline
    listInner.BorderMode = Enum.BorderMode.Inset
    listInner.BorderSizePixel = 0
    listInner.Size = UDim2.new(1,0,1,0)
    listInner.ZIndex = 21
    listInner.Parent = listOuter

    local scrolling = Instance.new("ScrollingFrame")
    scrolling.BackgroundTransparency = 1
    scrolling.BorderSizePixel = 0
    scrolling.CanvasSize = UDim2.new(0,0,0,0)
    scrolling.Size = UDim2.new(1,0,1,0)
    scrolling.ZIndex = 21
    scrolling.TopImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    scrolling.BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    scrolling.ScrollBarThickness = 3
    scrolling.ScrollBarImageColor3 = C.Accent
    scrolling.Parent = listInner

    Instance.new("UIListLayout", scrolling).SortOrder = Enum.SortOrder.LayoutOrder

    local function RecalcPos()
        listOuter.Position = UDim2.fromOffset(ddOuter.AbsolutePosition.X, ddOuter.AbsolutePosition.Y + 21)
    end
    local function RecalcSize(ySize)
        listOuter.Size = UDim2.fromOffset(ddOuter.AbsoluteSize.X, ySize or MAX_ITEMS*20+2)
    end
    RecalcPos(); RecalcSize()
    ddOuter:GetPropertyChangedSignal("AbsolutePosition"):Connect(RecalcPos)

    local function CloseDropdown()
        listOuter.Visible = false
        arrow.Rotation = 0
        if _openDropdownClose == CloseDropdown then
            _openDropdownClose = nil
        end
    end

    local function BuildList()
        for _, ch in pairs(scrolling:GetChildren()) do
            if not ch:IsA("UIListLayout") then ch:Destroy() end
        end
        local count = 0
        for _, val in ipairs(items) do
            count += 1
            local btn = Instance.new("Frame")
            btn.BackgroundColor3 = C.Main
            btn.BorderColor3 = C.Outline
            btn.BorderMode = Enum.BorderMode.Middle
            btn.Size = UDim2.new(1,-1,0,20)
            btn.ZIndex = 23
            btn.Active = true
            btn.LayoutOrder = count
            btn.Parent = scrolling

            local btnLabel = Instance.new("TextLabel")
            btnLabel.BackgroundTransparency = 1
            btnLabel.Position = UDim2.fromOffset(6,0)
            btnLabel.Size = UDim2.new(1,-6,1,0)
            btnLabel.Font = FONT
            btnLabel.TextColor3 = (val == selItem) and C.Accent or C.Font
            btnLabel.TextSize = 14
            btnLabel.TextStrokeTransparency = 0
            btnLabel.TextXAlignment = Enum.TextXAlignment.Left
            btnLabel.Text = val
            btnLabel.ZIndex = 25
            btnLabel.Parent = btn
            ApplyTextStroke(btnLabel)

            local thisVal = val
            btn.MouseEnter:Connect(function()
                if thisVal ~= selItem then btn.BorderColor3 = C.Accent; btn.ZIndex = 24 end
            end)
            btn.MouseLeave:Connect(function()
                if thisVal ~= selItem then btn.BorderColor3 = C.Outline; btn.ZIndex = 23 end
            end)
            btn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    selItem = thisVal
                    itemLabel.Text = thisVal
                    onChanged(thisVal)
                    CloseDropdown()
                    BuildList()
                end
            end)
        end
        scrolling.CanvasSize = UDim2.fromOffset(0, count*20+1)
        local y = math.clamp(count*20, 0, MAX_ITEMS*20) + 1
        RecalcSize(y)
    end
    BuildList()

    ddOuter.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            if listOuter.Visible then
                CloseDropdown()
            else
                if _openDropdownClose then _openDropdownClose() end
                _openDropdownClose = CloseDropdown
                RecalcPos()
                listOuter.Visible = true
                arrow.Rotation = 180
            end
        end
    end)

    UserInputService.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            local ap, as = listOuter.AbsolutePosition, listOuter.AbsoluteSize
            if Mouse.X < ap.X or Mouse.X > ap.X+as.X or Mouse.Y < (ap.Y-21) or Mouse.Y > ap.Y+as.Y then
                CloseDropdown()
            end
        end
    end)

    local function SetValue(v)
        selItem = v
        itemLabel.Text = v or "--"
        BuildList()
    end

    return ddOuter, SetValue
end

