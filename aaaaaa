    displayLabel.BackgroundTransparency = 1
    displayLabel.Size = UDim2.new(1,0,1,0)
    displayLabel.Font = FONT
    displayLabel.TextColor3 = C.Font
    displayLabel.TextSize = 14
    displayLabel.TextStrokeTransparency = 0
    displayLabel.ZIndex = 9
    displayLabel.Parent = sliderInner
    ApplyTextStroke(displayLabel)

    sliderOuter.MouseEnter:Connect(function() sliderOuter.BorderColor3 = C.Accent end)
    sliderOuter.MouseLeave:Connect(function() sliderOuter.BorderColor3 = C.Black end)

    local curValue = initVal

    local function MapValue(v, minA, maxA, minB, maxB)
        return (1 - ((v-minA)/(maxA-minA))) * minB + ((v-minA)/(maxA-minA)) * maxB
    end

    local function Round(v)
        if rounding == 0 then return math.floor(v) end
        return tonumber(string.format("%."..rounding.."f", v))
    end

    local function Display()
        local sfx = suffix or ""
        displayLabel.Text = string.format("%s/%s", curValue..sfx, maxVal..sfx)
        local x = math.ceil(MapValue(curValue, minVal, maxVal, 0, sliderMaxSize))
        fill.Size = UDim2.new(0, x, 1, 0)
        hideBorderRight.Visible = not (x == sliderMaxSize or x == 0)
    end

    Display()

    sliderInner.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            local mPosX = Mouse.X
            local gPos = fill.Size.X.Offset
            local diff = mPosX - (fill.AbsolutePosition.X + gPos)
            while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                local nX = math.clamp(gPos + (Mouse.X - mPosX) + diff, 0, sliderMaxSize)
                local rel = nX / sliderMaxSize
                local nVal = Round(minVal + rel * (maxVal - minVal))
                nVal = math.clamp(nVal, minVal, maxVal)
                if nVal ~= curValue then
                    curValue = nVal
                    Display()
                    onChanged(curValue)
                end
                RunService.RenderStepped:Wait()
            end
        end
    end)

    local function SetValue(v)
        curValue = math.clamp(Round(v), minVal, maxVal)
        Display()
    end

    return sliderOuter, SetValue
end

