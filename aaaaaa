            rgbBox2.Text = "255, 255, 255"; rgbBox2.TextColor3 = C.Font
            rgbBox2.TextSize = 14; rgbBox2.TextStrokeTransparency = 0
            rgbBox2.TextXAlignment = Enum.TextXAlignment.Left; rgbBox2.ZIndex = 20; rgbBox2.Parent = rbInner2
            ApplyTextStroke(rgbBox2)

            MakeDraggable(pickerOuter)

            local pH2, pS2, pV2 = Color3.toHSV(cd.initColor)

            local function DisplayPicker2()
                curColor = Color3.fromHSV(pH2, pS2, pV2)
                svMap2.BackgroundColor3 = Color3.fromHSV(pH2,1,1)
                swatchFrame.BackgroundColor3 = curColor
                swatchFrame.BorderColor3 = GetDarker(curColor)
                cursor2.Position = UDim2.new(pS2,0,1-pV2,0)
                hueCursor2.Position = UDim2.new(0,0,pH2,0)
                hexBox2.Text = "#"..curColor:ToHex()
                rgbBox2.Text = math.floor(curColor.R*255)..", "..math.floor(curColor.G*255)..", "..math.floor(curColor.B*255)
                cd.onChanged(curColor)
            end

            hexBox2.FocusLost:Connect(function(enter)
                if enter then local ok,res=pcall(Color3.fromHex,hexBox2.Text); if ok then pH2,pS2,pV2=Color3.toHSV(res) end end
                DisplayPicker2()
            end)
            rgbBox2.FocusLost:Connect(function(enter)
                if enter then local r,g,b=rgbBox2.Text:match("(%d+),%s*(%d+),%s*(%d+)"); if r then pH2,pS2,pV2=Color3.toHSV(Color3.fromRGB(r,g,b)) end end
                DisplayPicker2()
            end)
            svMap2.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                        local minX=svMap2.AbsolutePosition.X; local maxX=minX+svMap2.AbsoluteSize.X
                        local minY=svMap2.AbsolutePosition.Y; local maxY=minY+svMap2.AbsoluteSize.Y
                        pS2=(math.clamp(Mouse.X,minX,maxX)-minX)/(maxX-minX)
                        pV2=1-((math.clamp(Mouse.Y,minY,maxY)-minY)/(maxY-minY))
                        DisplayPicker2(); RunService.RenderStepped:Wait()
                    end
                end
            end)
            hueInner2.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                        local minY=hueInner2.AbsolutePosition.Y; local maxY=minY+hueInner2.AbsoluteSize.Y
                        pH2=(math.clamp(Mouse.Y,minY,maxY)-minY)/(maxY-minY)
                        DisplayPicker2(); RunService.RenderStepped:Wait()
                    end
                end
            end)

            local pickerOpen2 = false
            swatchFrame.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    if pickerOpen2 then
                        pickerOuter.Visible=false; pickerOpen2=false
                    else
                        for _,obj in pairs(ScreenGui:GetChildren()) do
                            if obj.Name=="Color" and obj~=pickerOuter then obj.Visible=false end
                        end
                        RecalcPickerPos(); pickerOuter.Visible=true; pickerOpen2=true
                    end
                end
            end)
            UserInputService.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    local ap,as=pickerOuter.AbsolutePosition,pickerOuter.AbsoluteSize
                    if Mouse.X<ap.X or Mouse.X>ap.X+as.X or Mouse.Y<(ap.Y-20) or Mouse.Y>ap.Y+as.Y then
                        if pickerOpen2 then pickerOuter.Visible=false; pickerOpen2=false end
                    end
                end
            end)

            DisplayPicker2()
        end
    end

    local function SetValue(v)
        state = v; refresh()
    end

    -- Row height is 18 (13px checkbox + 2 padding top/bottom)
    return toggleOuter, SetValue
end

