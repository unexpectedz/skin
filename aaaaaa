local selWeapon=nil; local selCosmetic=nil; local wCells={}; local cCells={}
local weaponOrder={}
for wname in pairs(WeaponSkins) do table.insert(weaponOrder,wname) end
table.sort(weaponOrder)

local function BuildWeaponGrid(filter)
    for _,c in pairs(wCells) do if c and c.frame then c.frame:Destroy() end end
    wCells={}; local idx=0
    for _,wname in ipairs(weaponOrder) do
        if not filter or filter=="" or wname:lower():find(filter:lower(),1,true) then
            idx+=1
            local cell=Instance.new("Frame"); cell.Size=UDim2.fromOffset(CELL_W,CELL_H)
            cell.BackgroundColor3=(selWeapon==wname) and C.Accent or C.ItemBG
            cell.BorderColor3=(selWeapon==wname) and C.Accent or C.ItemBord
            cell.BorderSizePixel=1; cell.ZIndex=6; cell.LayoutOrder=idx; cell.Parent=WeaponGrid
            local img=Instance.new("ImageLabel"); img.Size=UDim2.fromOffset(CELL_W-12,CELL_H-26)
            img.Position=UDim2.new(0.5,-(CELL_W-12)/2,0,3); img.BackgroundTransparency=1; img.Image=""
            img.ScaleType=Enum.ScaleType.Fit; img.ZIndex=7; img.Parent=cell
            local nl=MakeLabel(cell,wname,UDim2.new(1,-2,0,20),UDim2.new(0,1,1,-21),9,C.Font,Enum.TextXAlignment.Center,7)
            nl.TextWrapped=true
            local btn=Instance.new("TextButton"); btn.Size=UDim2.new(1,0,1,0); btn.BackgroundTransparency=1; btn.Text=""; btn.ZIndex=8; btn.Parent=cell
            local thisName=wname
            local cached=imageCache["W_"..thisName]
            if cached and cached~="" then img.Image=cached
            else task.defer(function() local id=GetWeaponImage(thisName); if id~="" and img and img.Parent then img.Image=id end end) end
            btn.MouseEnter:Connect(function() if selWeapon~=thisName then Tween(cell,{BackgroundColor3=C.Hover,BorderColor3=C.Accent},0.1) end end)
            btn.MouseLeave:Connect(function() if selWeapon~=thisName then Tween(cell,{BackgroundColor3=C.ItemBG,BorderColor3=C.ItemBord},0.1) end end)
            btn.MouseButton1Click:Connect(function()
                if wCells[selWeapon] then Tween(wCells[selWeapon].frame,{BackgroundColor3=C.ItemBG,BorderColor3=C.ItemBord},0.1) end
                selWeapon=thisName; selCosmetic=nil; Tween(cell,{BackgroundColor3=C.Accent,BorderColor3=C.Accent},0.1); RefreshCosmeticGrid()
            end)
            btn.MouseButton2Click:Connect(function()
                if SkinChanger.equipped[thisName] then
                    SkinChanger.equipped[thisName].Skin=nil
                    task.defer(function()
                        if wCells[thisName] then local id=GetWeaponImage(thisName); if id~="" then wCells[thisName].img.Image=id end end
                    end)
                end
            end)
            wCells[wname]={frame=cell,img=img}
        end
    end
    WeaponScroll.CanvasSize=UDim2.new(0,0,0,WGL.AbsoluteContentSize.Y+8)
end

RefreshCosmeticGrid=function()
    for _,c in pairs(cCells) do if c and c.frame then c.frame:Destroy() end end
    cCells={}; local items={}; local ft=CFilter.Text:lower()
    local useImage=TypeUsesImage(selCosType); local cellH=GetCellH(selCosType)
    CGL.CellSize=UDim2.fromOffset(RCELL_W,cellH)
    if selCosType=="skin" then
        if not selWeapon then CosScroll.CanvasSize=UDim2.new(0,0,0,0); return end
        items=WeaponSkins[selWeapon] or {}
    elseif selCosType=="wrap" then items=allWraps
    elseif selCosType=="charm" then items=allCharms end
    local idx=0
    for _,itemName in ipairs(items) do
        if ft=="" or itemName:lower():find(ft,1,true) then
            idx+=1
            local cell=Instance.new("Frame"); cell.Size=UDim2.fromOffset(RCELL_W,cellH)
            cell.BackgroundColor3=C.ItemBG; cell.BorderColor3=C.ItemBord; cell.BorderSizePixel=1; cell.ZIndex=6; cell.LayoutOrder=idx; cell.Parent=CosGrid
            local img=nil
            if useImage then
                img=Instance.new("ImageLabel"); img.Size=UDim2.fromOffset(RCELL_W-12,cellH-22)
                img.Position=UDim2.new(0.5,-(RCELL_W-12)/2,0,2); img.BackgroundTransparency=1; img.Image=""
                img.ScaleType=Enum.ScaleType.Fit; img.ZIndex=7; img.Parent=cell
            end
            local nlSize=useImage and UDim2.new(1,-2,0,18) or UDim2.new(1,-4,1,0)
            local nlPos=useImage and UDim2.new(0,1,1,-19) or UDim2.new(0,2,0,0)
            local nl=MakeLabel(cell,itemName,nlSize,nlPos,9,C.Font,Enum.TextXAlignment.Center,7); nl.TextWrapped=true
            local btn=Instance.new("TextButton"); btn.Size=UDim2.new(1,0,1,0); btn.BackgroundTransparency=1; btn.Text=""; btn.ZIndex=8; btn.Parent=cell
            local thisItem=itemName; local thisCell=cell; local thisType=selCosType
            if useImage and img then
                local ck="skin|"..thisItem
                if imageCache[ck] and imageCache[ck]~="" then img.Image=imageCache[ck]
                else task.defer(function() local id=GetSkinImage(thisItem); if id~="" and img and img.Parent then img.Image=id end end) end
            end
            btn.MouseEnter:Connect(function() if selCosmetic~=thisItem then Tween(thisCell,{BackgroundColor3=C.Hover,BorderColor3=C.Accent},0.1) end end)
            btn.MouseLeave:Connect(function() if selCosmetic~=thisItem then Tween(thisCell,{BackgroundColor3=C.ItemBG,BorderColor3=C.ItemBord},0.1) end end)
            btn.MouseButton1Click:Connect(function()
                if cCells[selCosmetic] then Tween(cCells[selCosmetic].frame,{BackgroundColor3=C.ItemBG,BorderColor3=C.ItemBord},0.1) end
                selCosmetic=thisItem; Tween(thisCell,{BackgroundColor3=C.Accent,BorderColor3=C.Accent},0.1)
                if thisType=="skin" and selWeapon then
                    if SkinChanger:ApplySkinModel(selWeapon,thisItem) then
                        saveSkinsFile(); ApplyLive(selWeapon)
                        task.defer(function()
                            local id=GetSkinImage(thisItem); if id=="" then id=GetWeaponImage(selWeapon) end
                            if wCells[selWeapon] and id~="" then wCells[selWeapon].img.Image=id end
                        end)
                    end
                elseif thisType=="wrap" and selWeapon then
                    local d=SkinChanger:CloneCosmetic(thisItem,"Wrap",{})
                    if d then
                        SkinChanger.equipped[selWeapon]=SkinChanger.equipped[selWeapon] or {}
                        SkinChanger.equipped[selWeapon].Wrap=d
                        SkinChanger.equipped[selWeapon].Name=selWeapon
                        saveSkinsFile()
                        ApplyLive(selWeapon)
                    end
                elseif thisType=="charm" and selWeapon then
                    local d=SkinChanger:CloneCosmetic(thisItem,"Charm",{})
                    if d then
                        SkinChanger.equipped[selWeapon]=SkinChanger.equipped[selWeapon] or {}
                        SkinChanger.equipped[selWeapon].Charm=d
                        SkinChanger.equipped[selWeapon].Name=selWeapon
                        saveSkinsFile()
                        ApplyLive(selWeapon)
                    end
                end
            end)
            cCells[thisItem]={frame=cell,img=img}
        end
    end
    CosScroll.CanvasSize=UDim2.new(0,0,0,CGL.AbsoluteContentSize.Y+8)
end

